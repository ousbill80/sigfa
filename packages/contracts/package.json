{
  "name": "@sigfa/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "generate": "node scripts/bundle.mjs && node scripts/generate.mjs",
    "lint": "eslint src",
    "lint:contract": "spectral lint openapi/*.yaml",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "mock": "node scripts/mock.mjs",
    "mock:stop": "pkill -f 'prism mock' || true"
  },
  "dependencies": {
    "@sigfa/schemas": "workspace:*",
    "openapi-fetch": "^0.12.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@redocly/cli": "^1.34.17",
    "@sigfa/config": "workspace:*",
    "@stoplight/prism-cli": "5.14.2",
    "@stoplight/spectral-cli": "^6",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "yaml": "^2"
  }
}
