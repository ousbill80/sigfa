{
  "name": "@sigfa/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "seed": "node --experimental-vm-modules dist/seed/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sigfa/config": "workspace:*",
    "@sigfa/testing": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.27.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
