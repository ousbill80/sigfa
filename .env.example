# SIGFA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env dans le dépôt.

# NODE_ENV=development

# ---------------------------------------------------------------------------
# INFRA-002 : Docker Compose dev — postgres16 + redis7 + api + web + kiosk
# Toutes les variables ci-dessous peuvent être surchargées dans .env
# sans modifier docker-compose.yml.
# ---------------------------------------------------------------------------

# PostgreSQL (service postgres, image postgres:16)
# POSTGRES_PORT=5432
# POSTGRES_DB=sigfa
# POSTGRES_USER=sigfa
# POSTGRES_PASSWORD=sigfa

# Redis (service redis, image redis:7)
# REDIS_PORT=6379

# Services applicatifs dev (node:22-slim, hot reload via bind mount)
# API_PORT=3001
# WEB_PORT=3000
# KIOSK_PORT=3002

# ---------------------------------------------------------------------------
# DB-008 : Chiffrement AES-256-GCM applicatif des téléphones + HMAC de recherche
# Chiffrement APPLICATIF (jamais pgcrypto) : ces clés ne transitent JAMAIS vers
# PostgreSQL — les dumps SQL sont chiffrés par construction.
# Le module src/crypto/phone-cipher.ts échoue AU DÉMARRAGE si une clé est absente
# ou de mauvaise taille (jamais de repli en clair).
# ---------------------------------------------------------------------------

# Clé de chiffrement AES-256-GCM (EXACTEMENT 32 octets = 64 caractères hexadécimaux).
# Génération : openssl rand -hex 32
# PHONE_ENCRYPTION_KEY=

# Clé HMAC-SHA256 pour le phone_hash déterministe (colonne de recherche).
# Secret quelconque non vide — recommandé 32 octets.
# Génération : openssl rand -hex 32
# PHONE_HASH_KEY=

# ---------------------------------------------------------------------------
# CONTRACT-009b : Ports des mocks Prism par module OpenAPI
# Lancés par : pnpm --filter @sigfa/contracts mock
# Arrêtés par : pnpm --filter @sigfa/contracts mock:stop
# ---------------------------------------------------------------------------
# MOCK_CORE_PORT=4010
# MOCK_PUBLIC_PORT=4011
# MOCK_AGENTS_PORT=4012
# MOCK_ADMIN_PORT=4013
# MOCK_REPORTING_PORT=4014
# MOCK_NOTIFICATIONS_PORT=4015
# MOCK_AI_PORT=4016
