# SIGFA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env dans le dépôt.

# NODE_ENV=development

# ---------------------------------------------------------------------------
# INFRA-002 : Docker Compose dev — postgres16 + redis7 + api + web + kiosk
# Toutes les variables ci-dessous peuvent être surchargées dans .env
# sans modifier docker-compose.yml.
# ---------------------------------------------------------------------------

# PostgreSQL (service postgres, image postgres:16)
# POSTGRES_PORT=5432
# POSTGRES_DB=sigfa
# POSTGRES_USER=sigfa
# POSTGRES_PASSWORD=sigfa

# Redis (service redis, image redis:7)
# REDIS_PORT=6379

# Services applicatifs dev (node:22-slim, hot reload via bind mount)
# API_PORT=3001
# WEB_PORT=3000
# KIOSK_PORT=3002

# ---------------------------------------------------------------------------
# DB-009 : Mots de passe des rôles PostgreSQL (DEV uniquement — NE PAS utiliser en prod)
# Ces défauts sont injectés dans la migration 0001_rls.sql via current_setting().
# En production : définir SIGFA_MIGRATOR_PASSWORD et SIGFA_APP_PASSWORD AVANT
# d'appliquer les migrations (SET app.sigfa_migrator_password = '...' en session).
# Rotation prod : changer le mot de passe avec ALTER ROLE sigfa_app PASSWORD '...'.
# ---------------------------------------------------------------------------

# Mot de passe DEV du rôle migrateur (BYPASSRLS). NE PAS utiliser en production.
# SIGFA_MIGRATOR_PASSWORD=sigfa_migrator_dev

# Mot de passe DEV du rôle applicatif (sigfa_app). NE PAS utiliser en production.
# SIGFA_APP_PASSWORD=sigfa_app_dev

# ---------------------------------------------------------------------------
# DB-008 : Chiffrement AES-256-GCM applicatif des téléphones + HMAC de recherche
# Chiffrement APPLICATIF (jamais pgcrypto) : ces clés ne transitent JAMAIS vers
# PostgreSQL — les dumps SQL sont chiffrés par construction.
# Le module src/crypto/phone-cipher.ts échoue AU DÉMARRAGE si une clé est absente
# ou de mauvaise taille (jamais de repli en clair).
# ---------------------------------------------------------------------------

# Clé de chiffrement AES-256-GCM (EXACTEMENT 32 octets = 64 caractères hexadécimaux).
# Génération : openssl rand -hex 32
# PHONE_ENCRYPTION_KEY=

# Clé HMAC-SHA256 pour le phone_hash déterministe (colonne de recherche).
# DB-009 (MAJOR) : EXACTEMENT 64 caractères hexadécimaux (32 octets) exigés.
# Le module src/crypto/phone-cipher.ts échoue AU DÉMARRAGE si invalide (fail-fast).
# Génération : openssl rand -hex 32
# PHONE_HASH_KEY=

# ---------------------------------------------------------------------------
# API-001 : Authentification JWT et Redis (obligatoires en production)
# ---------------------------------------------------------------------------

# Secret JWT — MINIMUM 32 caractères. L'API échoue au démarrage si absent ou trop court.
# Génération : openssl rand -hex 32
# JWT_SECRET=

# URL de connexion Redis (pour refresh tokens, rotation, verrouillage login)
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# API-007 : Alertes manager — intervalles des scans BullMQ repeatable + grâce
# anti-flap socket. Toutes injectables ; défauts sûrs si absentes.
# Source : apps/api/src/config/alerting.ts
# ---------------------------------------------------------------------------

# Intervalle (secondes) du job `inactive-agent-scan` (AGENT_INACTIVE). Défaut 60.
# AGENT_INACTIVE_SCAN_INTERVAL_S=60

# Intervalle (secondes) du job `sla-scan` (SLA_BREACH / escalated). Défaut 60.
# SLA_SCAN_INTERVAL_S=60

# Fenêtre de grâce anti-flap par agentId à la déconnexion socket (secondes). Défaut 30.
# AGENT_DISCONNECT_GRACE_S=30

# ---------------------------------------------------------------------------
# NOTIF-001 : Infrastructure BullMQ de notification — retry/backoff, DLQ,
# débit par canal, isolation par prefix. Toutes injectables ; défauts D3.
# Source : apps/api/src/config/notifications.ts
# ---------------------------------------------------------------------------

# Base du backoff exponentiel plafonné (ms). Défaut 5000 (5 s).
# NOTIF_BACKOFF_BASE_MS=5000

# Plafond du backoff (ms). Défaut 300000 (5 min).
# NOTIF_BACKOFF_CAP_MS=300000

# Nombre maximal de tentatives avant dead-letter. Défaut 5.
# NOTIF_MAX_ATTEMPTS=5

# Débit (concurrency BullMQ) du worker PAR canal — throttle fournisseur. Défaut 5.
# NOTIF_CHANNEL_CONCURRENCY=5

# Prefix Redis des files (isolation PAR environnement). Défaut "sigfa".
# NOTIF_QUEUE_PREFIX=sigfa

# ---------------------------------------------------------------------------
# NET-003 : Observabilité (Grafana/Sentry) — seuils d'alerte infra + destinataires.
# Seuils as-code, injectables. Calibrage réel GATED sur le run de charge SEC-004.
# Destinataires ops/astreinte = PLACEHOLDERS, valeurs réelles fournies par le PO/ops.
# Source : apps/api/src/config/observability.ts
# ---------------------------------------------------------------------------
# Seuil CPU (fraction 0..1). Défaut 0.80 (>80%).
# OBS_CPU_THRESHOLD=0.80
# Seuil mémoire (fraction 0..1). Défaut 0.85 (>85%).
# OBS_MEM_THRESHOLD=0.85
# Seuil taux d'erreur 5xx (fraction 0..1). Défaut 0.01 (>1%).
# OBS_ERROR_RATE_THRESHOLD=0.01
# SLA latence RT ticket:called p95 (ms). Défaut 500 (aligné SEC-004).
# OBS_RT_P95_SLA_MS=500
# Fenêtre d'évaluation soutenue (secondes). Défaut 300 (5 min).
# OBS_WINDOW_S=300
# Fenêtre de dédup / regroupement d'alertes (secondes). Défaut 600 (10 min).
# OBS_DEDUP_WINDOW_S=600
# Destinataire ops (WARNING) — PLACEHOLDER, à fournir par le PO/ops.
# OBS_OPS_RECIPIENT=slack://ops
# Destinataire astreinte on-call (CRITICAL) — PLACEHOLDER, à fournir par le PO/ops.
# OBS_ONCALL_RECIPIENT=pagerduty://on-call

# ---------------------------------------------------------------------------
# CONTRACT-009b : Ports des mocks Prism par module OpenAPI
# Lancés par : pnpm --filter @sigfa/contracts mock
# Arrêtés par : pnpm --filter @sigfa/contracts mock:stop
# ---------------------------------------------------------------------------
# MOCK_CORE_PORT=4010
# MOCK_PUBLIC_PORT=4011
# MOCK_AGENTS_PORT=4012
# MOCK_ADMIN_PORT=4013
# MOCK_REPORTING_PORT=4014
# MOCK_NOTIFICATIONS_PORT=4015
# MOCK_AI_PORT=4016
