# SIGFA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env dans le dépôt.

# NODE_ENV=development

# ---------------------------------------------------------------------------
# INFRA-002 : Docker Compose dev — postgres16 + redis7 + api + web + kiosk
# Toutes les variables ci-dessous peuvent être surchargées dans .env
# sans modifier docker-compose.yml.
# ---------------------------------------------------------------------------

# PostgreSQL (service postgres, image postgres:16)
# POSTGRES_PORT=5432
# POSTGRES_DB=sigfa
# POSTGRES_USER=sigfa
# POSTGRES_PASSWORD=sigfa

# Redis (service redis, image redis:7)
# REDIS_PORT=6379

# Services applicatifs dev (node:22-slim, hot reload via bind mount)
# API_PORT=3001
# WEB_PORT=3000
# KIOSK_PORT=3002
