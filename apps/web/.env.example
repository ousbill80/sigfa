# Mock Prism canonique unifié (web + kiosk) — RT-001b.
# En "off"/mock : le mock Prism ; en "real" : l'URL de l'API réelle.
NEXT_PUBLIC_API_URL=http://localhost:4010

# Bascule temps réel côté client (RT-001b) : "off" (défaut = fixtures F4, aucune
# connexion socket, SocketProvider inactif) ou "real" (ouvre la connexion socket.io
# vers NEXT_PUBLIC_API_URL avec le JWT en handshake, join:agency + sync:request).
# L'autorité serveur reste REALTIME_MODE (apps/api) ; côté client l'URL suit le mode.
NEXT_PUBLIC_REALTIME_MODE=off

# NOTE mobile = PENDING (RT-001) : la bascule socket mobile est une story
# ultérieure (dep socket.io-client + contrainte Metro). Le polling (cache 30 s)
# reste le défaut mobile — hors périmètre web.

# RT-003 — écran mural /tv/[agencyId] : en mode "real", l'écran mint un token
# d'affichage DISPLAY (lecture seule, TTL 12 h, non renouvelable) via
# POST {NEXT_PUBLIC_API_URL}/tv/session { agencyId } (route PUBLIQUE, aucun
# Bearer agent, aucune PII), puis le passe au handshake socket. Aucune variable
# d'env dédiée : le flux réutilise NEXT_PUBLIC_API_URL (mint REST) + son origine
# (socket) et NEXT_PUBLIC_REALTIME_MODE. En "off", aucun mint (fixtures F4).

# S1 (Boucle 2 F4) — secret de vérification des JWT de session (jose, HS256
# explicite, même politique que apps/api : ≥32 caractères, MÊME secret que
# l'API qui signe). Le middleware Next VÉRIFIE la signature du cookie
# access_token AVANT tout RBAC de pages. Fail-closed : absent ou trop court →
# aucun token accepté, toutes les routes protégées redirigent vers /login.
# NB : les tokens émis par le mock Prism ne sont PAS signés — pour naviguer
# les pages protégées en mode mock, poser un cookie signé avec ce secret.
# Secret serveur uniquement — ne JAMAIS le préfixer NEXT_PUBLIC_.
JWT_SECRET=change-me-32-characters-minimum-secret

# Connexion démo directe par rôle — DEV/TEST UNIQUEMENT (voir .env.example
# racine pour le détail). OFF par défaut : sans SIGFA_DEMO_LOGIN=1 la page de
# login est strictement inchangée et /api/auth/demo-login répond 404.
# Secrets serveur uniquement — ne JAMAIS les préfixer NEXT_PUBLIC_.
# SIGFA_DEMO_LOGIN=1
# DEMO_LOGIN_PASSWORD_BANK_ADMIN=
# DEMO_LOGIN_PASSWORD_AGENCY_DIRECTOR=
# DEMO_LOGIN_PASSWORD_MANAGER=
# DEMO_LOGIN_PASSWORD_AGENT=
# DEMO_LOGIN_PASSWORD_AUDITOR=

# WEB-002-HDR — marque banque du bandeau session (toutes consoles connectées).
# Même convention de provisionnement que apps/kiosk (kiosk-branding) : nom
# public de la banque + URL de logo optionnelle (PNG/SVG fond transparent).
# Sans logo, le bandeau retombe sur la pastille --brand + initiale — aucun
# asset n'est jamais requis pour brander une banque. NOTE : ces envs seront
# remplacées par l'endpoint theme tenant (GET /public/banks/{id}/theme) —
# chantier theming parallèle en cours.
NEXT_PUBLIC_BANK_NAME=SIGFA
# NEXT_PUBLIC_BANK_LOGO_URL=

# Écran TV d'agence (/tv/[agencyId]) — zone média gauche (images + vidéos qui
# défilent). Manifeste JSON : par défaut /tv-media/manifest.json servi depuis
# apps/web/public/tv-media/ (format documenté dans public/tv-media/README.md).
# Cette URL surcharge le manifeste (ex. manifeste hébergé par la banque). Sans
# manifeste/médias, l'écran retombe sur les slides promo texte — aucun asset
# requis. NOTE : le pilotage par la console admin remplacera ce manifeste
# statique (couture : src/lib/tv-media.ts).
# NEXT_PUBLIC_TV_MEDIA_MANIFEST_URL=
