# Mock Prism canonique unifié (web + kiosk) — RT-001b.
# En "off"/mock : le mock Prism ; en "real" : l'URL de l'API réelle.
NEXT_PUBLIC_API_URL=http://localhost:4010

# Bascule temps réel côté client (RT-001b) : "off" (défaut = fixtures F4, aucune
# connexion socket, SocketProvider inactif) ou "real" (ouvre la connexion socket.io
# vers NEXT_PUBLIC_API_URL avec le JWT en handshake, join:agency + sync:request).
# L'autorité serveur reste REALTIME_MODE (apps/api) ; côté client l'URL suit le mode.
NEXT_PUBLIC_REALTIME_MODE=off

# NOTE mobile = PENDING (RT-001) : la bascule socket mobile est une story
# ultérieure (dep socket.io-client + contrainte Metro). Le polling (cache 30 s)
# reste le défaut mobile — hors périmètre web.
