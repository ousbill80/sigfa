# Mock Prism canonique unifié (web + kiosk) — RT-001b.
MOCK_API_URL=http://localhost:4010
NEXT_PUBLIC_API_URL=${MOCK_API_URL}

# Bascule temps réel côté client (RT-001b) : "off" (défaut = fixtures F4, aucune
# connexion socket) ou "real" (ouvre io(NEXT_PUBLIC_API_URL, { auth:{ token }})).
# L'autorité serveur reste REALTIME_MODE (apps/api) ; côté client l'URL suit le mode.
NEXT_PUBLIC_REALTIME_MODE=off

# Provisionnement de la session borne (KIOSK-001, câblé Boucle 2 F4/S5).
# Ces variables sont lues UNIQUEMENT par le processus principal Electron
# (electron/main.ts) qui crée la session (POST /kiosk/session) et ne renvoie
# que le JWT au renderer via IPC (preload contextBridge).
# INTERDIT : ne jamais les exposer en NEXT_PUBLIC_* (elles seraient dans le
# bundle client d'une borne partagée).
KIOSK_ID=kiosk-dev-01
KIOSK_SECRET=dev-secret
AGENCY_ID=agency-dev-01

# URL de l'API utilisée par le main process pour la session borne.
# Défaut : MOCK_API_URL puis http://localhost:4010 (mock Prism canonique).
# KIOSK_API_URL=http://localhost:4010

# Identité publique affichée par la borne (accueil + bandeau d'en-tête +
# ticket imprimé). Données d'enseigne, non-PII. Replis : "SIGFA" / "Agence Centrale".
NEXT_PUBLIC_BANK_NAME=SIGFA
NEXT_PUBLIC_AGENCY_NAME=Agence Centrale

# Logo de la banque (theming sans effort) — OPTIONNEL. URL absolue ou chemin
# public (ex. /branding/logo.svg). PNG/SVG à fond transparent recommandé ;
# affiché ~112 px de haut sur l'accueil, 56 px dans le bandeau d'en-tête.
# Vide ou absent = repli élégant : pastille --brand + initiale de la banque
# (aucune image requise pour brander une borne).
# NEXT_PUBLIC_BANK_LOGO_URL=https://cdn.exemple.ci/banques/logo.svg

# Impression silencieuse Electron (canal IPC kiosk:print-ticket).
# Nom de l'imprimante thermique 80 mm vue par l'OS ; vide = imprimante par défaut.
# SIGFA_KIOSK_PRINTER=EPSON-TM-T20III

# NOTE mobile = PENDING (RT-001) : la bascule socket mobile est une story
# ultérieure (dep socket.io-client + contrainte Metro). Le polling (cache 30 s)
# reste le défaut mobile — sans rapport avec cette borne.

# Theming tenant de la borne (CONTRACT-013) : identifiant PUBLIC de la banque.
# Quand il est défini, l'écran d'accueil charge GET /public/banks/{id}/theme
# (route publique, zéro PII) : logo + couleurs appliquées (--brand recalculé
# WCAG). Absent => AUCUNE requête, repli monogramme (initiales) teinté --brand.
# NEXT_PUBLIC_BANK_ID=11111111-1111-4111-a111-111111111111

# Identité publique affichée par la borne (écran de marque de l'accueil).
# Donnée d'enseigne, non-PII. Repli : "SIGFA".
NEXT_PUBLIC_BANK_NAME=SIGFA
