{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sigfa/contracts": ["../../packages/contracts/dist/src/client.d.ts"],
      // Unifie les types React sur UNE seule copie (@types/react local) — évite
      // le conflit de doublon @types/react (18 mobile / 19) quand tsc compile la
      // source de @sigfa/ui (package source-exported). Même parade qu'apps/web.
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright.config.ts", "next.config.playwright.ts", "src/__tests__/visual/**"]
}
