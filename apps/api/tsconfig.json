{
  "extends": "@sigfa/config/tsconfig/base",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    // JSX pour les gabarits React Email (NOTIF-004) rendus côté serveur.
    // `react-jsx` = runtime automatique (aucun import React explicite requis).
    "jsx": "react-jsx",
    "paths": {
      "src/*": ["./src/*"],
      "@sigfa/contracts/events/realtime.js": [
        "../../packages/contracts/dist/events/realtime.d.ts"
      ]
    }
  },
  "include": ["src/**/*"]
}
