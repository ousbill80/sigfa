# Variables d'environnement — @sigfa/api
#
# Chiffrement des téléphones au repos (DB-008) — requis au démarrage.
# Le barrel @sigfa/database (importé par les routeurs admin API-008 via
# insertAuditEntry) charge le module crypto avec validation fail-fast des clés.
# 32 octets = 64 caractères hexadécimaux.
PHONE_ENCRYPTION_KEY=1111111111111111111111111111111111111111111111111111111111111111
PHONE_HASH_KEY=2222222222222222222222222222222222222222222222222222222222222222

# Stockage objet Cloudflare R2 (S3-compatible) — theming logo (API-009).
# Utilisé par GET /banks/{id}/theme/logo-upload-url pour générer une URL présignée
# (SigV4 local, sans appel réseau). En DEV, laisser ces variables VIDES : la route
# répond alors 503 R2_NOT_CONFIGURED (jamais de crash). L'upload réel = déploiement.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
