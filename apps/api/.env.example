# Variables d'environnement — @sigfa/api
#
# Chiffrement des téléphones au repos (DB-008) — requis au démarrage.
# Le barrel @sigfa/database (importé par les routeurs admin API-008 via
# insertAuditEntry) charge le module crypto avec validation fail-fast des clés.
# 32 octets = 64 caractères hexadécimaux.
PHONE_ENCRYPTION_KEY=1111111111111111111111111111111111111111111111111111111111111111
PHONE_HASH_KEY=2222222222222222222222222222222222222222222222222222222222222222

# Stockage objet Cloudflare R2 (S3-compatible) — theming logo (API-009).
# Utilisé par GET /banks/{id}/theme/logo-upload-url pour générer une URL présignée
# (SigV4 local, sans appel réseau). En DEV, laisser ces variables VIDES : la route
# répond alors 503 R2_NOT_CONFIGURED (jamais de crash). L'upload réel = déploiement.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto

# Supervision des bornes kiosques (API-011) — constantes de domaine.
# KIOSK_HEARTBEAT_INTERVAL_S : cadence nominale du heartbeat borne (LA LOI v1 = 60 s).
# Une borne est SILENT si son dernier heartbeat date de plus de 3× cet intervalle
# (seuil = 180 s). Ces valeurs sont figées par LA LOI (voir src/config/kiosk.ts) et
# ne sont PAS lues depuis l'environnement — elles sont documentées ici à titre indicatif.
KIOSK_HEARTBEAT_INTERVAL_S=60

# Confiance au proxy amont (SEC — Boucle 3 F3). Détermine si les en-têtes
# `X-Forwarded-For` / `X-Real-IP` (FALSIFIABLES par le client) sont pris en compte
# pour dériver l'IP cliente du rate-limit et de l'audit.
# - `false` (DÉFAUT, recommandé sans proxy de confiance) : XFF/X-Real-IP IGNORÉS,
#   on utilise l'IP de la connexion TCP réelle. Un attaquant ne peut PAS
#   réinitialiser sa fenêtre de rate-limit ni usurper une IP d'audit via un XFF forgé.
# - `true` : à n'activer QUE si l'API est DERRIÈRE un proxy/load-balancer de confiance
#   qui écrase/positionne lui-même `X-Forwarded-For` (Cloudflare, Nginx interne…).
TRUST_PROXY=false

# Canal email interne (NOTIF-004) — Resend derrière interface, MOCK en CI.
# AUCUN envoi réseau réel n'est effectué tant que l'adaptateur mock est branché.
# - EMAIL_INTERNAL_DOMAINS : allow-list (séparée par virgules) des domaines internes
#   (staff de la banque). Toute adresse HORS de cette liste est REFUSÉE — un email
#   client final ne part JAMAIS (destinataires internes uniquement, aucun opt-in UEMOA).
# - EMAIL_FROM : adresse d'expédition (domaine banque, SPF/DKIM à configurer en prod).
# - EMAIL_ATTACHMENT_SIGNING_SECRET : secret HMAC des liens signés de pièce jointe.
# - EMAIL_ATTACHMENT_BASE_URL : base d'URL publique de téléchargement des pièces jointes.
# - EMAIL_ATTACHMENT_LIMIT_BYTES : plafond au-delà duquel une pièce jointe bascule en
#   lien signé à TTL 24 h (D3) au lieu d'être jointe (défaut ~25 Mo).
EMAIL_INTERNAL_DOMAINS=sigfa.local
EMAIL_FROM=no-reply@sigfa.local
EMAIL_ATTACHMENT_SIGNING_SECRET=dev-attachment-signing-secret
EMAIL_ATTACHMENT_BASE_URL=https://storage.sigfa.local/attachments
EMAIL_ATTACHMENT_LIMIT_BYTES=26214400

# Fournisseur d'envoi email (RESEND-EMAIL). Le mock (NOTIF-004) reste le DÉFAUT en
# dev/CI : AUCUN envoi réseau réel tant que `EMAIL_PROVIDER` ≠ `resend`.
# - EMAIL_PROVIDER : `mock` (défaut) ou `resend`. `resend` n'est activé que si
#   RESEND_API_KEY ET RESEND_FROM sont renseignés (sinon repli mock, jamais de crash).
# - RESEND_API_KEY : clé API Resend (SECRET). LAISSER VIDE ici — jamais de vraie clé
#   commitée. Renseignée uniquement en déploiement via l'environnement.
# - RESEND_FROM : adresse d'expédition validée côté Resend (ex. nepasrepondre@prodestic.net).
EMAIL_PROVIDER=mock
RESEND_API_KEY=
RESEND_FROM=

# Jeton QR agence signé (NOTIF-005-A / CONTRACT-013). Le QR affiché en agence
# encode un identifiant d'agence SIGNÉ (non-PII) que la PWA renvoie pour émettre
# un ticket via le canal QR. Format : HMAC-SHA256 sur { agencyId, exp, keyVersion },
# TTL 30 jours, clé ROTATIVE VERSIONNÉE (vérification multi-version côté serveur).
# - AGENCY_QR_SIGNING_KEYS : trousseau `version:secret` séparé par virgules
#   (ex. `1:ancien-secret,2:secret-courant`). Toute version listée reste ACCEPTÉE
#   en vérification (rotation sans casser les QR encore dans leur fenêtre de 30 j).
#   Retirer une version de la liste invalide progressivement les anciens QR.
#   En DEV, laisser VIDE → clé de dev v1 par défaut (JAMAIS en prod).
# - AGENCY_QR_KEY_VERSION : version courante de SIGNATURE (défaut : plus haute
#   version présente dans AGENCY_QR_SIGNING_KEYS).
# - AGENCY_QR_PWA_BASE_URL : base d'URL de la PWA (défaut DEV https://app.sigfa.local/q).
AGENCY_QR_SIGNING_KEYS=
AGENCY_QR_KEY_VERSION=
AGENCY_QR_PWA_BASE_URL=https://app.sigfa.local/q

# Bascule temps réel serveur (RT-001a, D2). Variable AUTORITAIRE côté API.
# - `off` (DÉFAUT, y compris tous les tests) : bus `createNoopBus` validant,
#   AUCUN serveur Socket.io, AUCUN scheduler d'alertes BullMQ démarré. C'est le
#   comportement de non-régression des suites F3.
# - `real` : `serve()` capture le httpServer → `createSocketServer` (HTTP+WS même
#   port) → `createSocketBus` (adaptateur contrat) → `startAlertScheduler`.
#   SIGTERM/SIGINT → arrêt gracieux (io.close → drain BullMQ → PG/Redis), zéro orphelin.
REALTIME_MODE=off

# Canal SMS (SMS-SMPP) — fournisseur IAM via SMPP, sender ZENAPI, derrière
# l'interface `SmsAdapter` (NOTIF-002). Le MOCK reste le DÉFAUT en dev/CI (aucun
# réseau). Le VRAI adaptateur SMPP s'active UNIQUEMENT si `SMS_PROVIDER=smpp` ET
# la config ci-dessous est complète (host + system_id + password).
#
# SÉCURITÉ : ne JAMAIS committer de vraie valeur/secret ici. Ces variables sont
# des NOMS avec des valeurs VIDES ; les secrets réels vivent dans `.env` (ignoré).
# - SMS_PROVIDER : `smpp` | `mock` (défaut `mock`).
# - SMPP_HOST / SMPP_PORT : SMSC IAM (port défaut 2775).
# - SMPP_SYSTEM_ID / SMPP_PASSWORD : identifiants de bind (jamais journalisés).
# - SMS_SENDER_ID : adresse source affichée (=`ZENAPI`).
# - SMPP_SOURCE_TON=5 (alphanumérique) / SMPP_SOURCE_NPI=0 : TON/NPI de la source.
# - SMPP_DEST_TON=0 / SMPP_DEST_NPI=1 : TON/NPI du destinataire.
# - SMPP_ENABLE_DLR=1 : demander les accusés de livraison (DLR) au SMSC.
SMS_PROVIDER=mock
SMPP_HOST=
SMPP_PORT=2775
SMPP_SYSTEM_ID=
SMPP_PASSWORD=
SMS_SENDER_ID=ZENAPI
SMPP_SOURCE_TON=5
SMPP_SOURCE_NPI=0
SMPP_DEST_TON=0
SMPP_DEST_NPI=1
SMPP_ENABLE_DLR=1

# Feature-store IA (F10-FEATURE-STORE) — SOURCE des features du forecast
# (`GET /ai/forecast`). Le DÉFAUT SÛR est `none` : aucune matérialisation lue → le
# forecast reste gaté à 422 INSUFFICIENT_HISTORY (comportement historique inchangé).
# Le feature-store DB-backed (`DbFeatureStore` sur la table `ai_features`, migration
# 0013) s'active UNIQUEMENT si `FEATURE_STORE_PROVIDER=db` : la lecture `ai_features`
# passe alors par `withArmedTenant` (connexion `sigfa_app` NOBYPASSRLS + RLS armée).
# - FEATURE_STORE_PROVIDER : `db` | `none` (défaut `none`).
FEATURE_STORE_PROVIDER=none
