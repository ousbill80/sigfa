{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "SEC-005 — mutation testing StrykerJS borné au CŒUR métier uniquement (moteur de file + sla-engine). Seuil de sortie produit : score >= 60%. NE mute PAS tout le monorepo. Runner Vitest scopé via vitest.mutation.config.ts (2 suites déterministes, zéro Testcontainers).",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.mutation.config.ts"
  },
  "reporters": ["html", "json", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/services/queue-engine.ts",
    "src/reporting/sla-engine.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "timeoutMS": 10000,
  "timeoutFactor": 2,
  "concurrency": 4,
  "disableTypeChecks": true,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
