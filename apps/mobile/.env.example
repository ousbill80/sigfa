# apps/mobile/.env.example — variables d'environnement Expo (EXPO_PUBLIC_*)
# Copier vers .env et adapter. Les variables EXPO_PUBLIC_* sont embarquées
# dans le bundle client : n'y mettre AUCUN secret.

# URL de base de l'API SIGFA consommée par l'app mobile.
# Dev : mock Prism du contrat (pnpm --filter @sigfa/contracts mock) ou API locale.
# Utilisée par : services/api.ts, hooks/useTicketPolling.ts, services/ticket-mmkv.ts (flush S7).
EXPO_PUBLIC_API_URL=http://localhost:4000

# Active le service WebSocket MOCK (événements queue:updated / ticket:called
# simulés) tant que le backend temps réel n'est pas branché ('true'/'false').
EXPO_PUBLIC_MOCK_WS=true

# Active la Live Activity iOS / notification persistante Android du ticket
# vivant (MOB-003) — flag maintenu à 'false' en F4 ('true'/'false').
EXPO_PUBLIC_LIVE_ACTIVITY=false
